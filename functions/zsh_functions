function tmux2() {
tmux new-session \; split-window -h \; attach

}

function tmux3() {
tmux new-session \; split-window -h \; select-pane -t 1 \; split-window -v \; attach

}

#__________________________________________________CLI_TOOLS

# Modern CLI tool aliases and functions
if command -v exa &> /dev/null; then
    alias ls="exa --color=auto --group-directories-first"
    alias ll="exa -la --color=auto --group-directories-first"
    alias la="exa -a --color=auto --group-directories-first"
    alias tree="exa --tree"
    alias lt="exa -la --sort=modified --reverse"  # List by time
fi

if command -v bat &> /dev/null; then
    alias cat="bat --style=plain --paging=never"
    alias batl="bat --style=numbers,changes --paging=auto"  # bat with line numbers
    export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

if command -v fdfind &> /dev/null; then
    alias fd="fdfind"
    alias find="fdfind"
elif command -v fd &> /dev/null; then
    alias find="fd"
fi

if command -v rg &> /dev/null; then
    alias grep="rg --color=auto"
    alias rgi="rg -i"  # case insensitive
    alias rgf="rg --files"  # list files that would be searched
fi

#__________________________________________________GIT
function conf2git() {

 local current_dir
  current_dir=$(pwd)


  # Переходим в директорию ~/.aux
  if [ -d "$HOME/.aux" ]; then
    cd "$HOME/.aux" || { echo "Failed to enter ~/.aux directory"; return 1; }
  else
    echo "Directory ~/.aux does not exist!"
    return 1
  fi

  # Добавляем все изменения
  git add .

  # Проверяем, есть ли параметры командной строки
  if [ $# -eq 0 ]; then
    # Если параметров нет, используем стандартный комментарий
    git commit -m "Some changes"
  else
    # Если параметры есть, используем их как комментарий
    git commit -m "$*"
  fi

  # Выполняем git push
  git push

   # Возвращаемся в изначальную директорию
  cd "$current_dir" || { echo "Failed to return to the original directory"; return 1; }
}



function git2conf() {
 # Запоминаем текущую директорию
  local current_dir
  current_dir=$(pwd)

  # Переходим в директорию ~/.aux
  if [ -d "$HOME/.aux" ]; then
    cd "$HOME/.aux" || { echo "Failed to enter ~/.aux directory"; return 1; }
  else
    echo "Directory ~/.aux does not exist!"
    return 1
  fi

  # Выполняем git pull
  echo "Pulling latest changes from origin/main..."
  git pull origin main || { echo "Failed to pull changes!"; return 1; }

  echo "Successfully pulled changes."
   # Возвращаемся в изначальную директорию
  cd "$current_dir" || { echo "Failed to return to the original directory"; return 1; }
}

